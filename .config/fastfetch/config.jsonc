{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "modules": [
        "title",
        "os",
        "uptime",
        {
            "type": "battery",
            "format": "{/4}{-}{/}{4}{?5} [{5}]{?}"
        },
        "packages",
        "shell",
        "terminal",
        "memory"
    ],
    "logo": {
        "type": "small",
        "padding": {
          "left": 2
        }
    }
}


